# Dépendances
node_modules

# Sorties de build
dist
dist-ssr
.output
.nitro
.vinxi
.wrangler

# Caches TanStack / Vite
.tanstack
.vite

# Variables d'environnement & secrets
# (tout .env est ignoré SAUF le modèle .env.example, versionné)
.env
.env.*
!.env.example
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests / couverture
coverage

# TypeScript
*.tsbuildinfo

# Supabase CLI (les fichiers .sql versionnés dans supabase/ restent suivis)
supabase/.temp
supabase/.branches
supabase/.env

# Éditeurs / IDE
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Fichiers système (OS)
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Exports PMS bruts (données clients / PII : noms, notes, réfs CB…) — JAMAIS
# versionnés. Servent uniquement aux tests locaux ; la table Supabase ne
# persiste que des données minimisées (voir src/lib/pdj/).
csv/
doc/

# Captures d'écran de travail : elles montrent des écrans peuplés de vraies
# données (noms de clients, montants), et n'ont pas leur place dans l'historique.
screenshot/

# OCR tesseract : les binaires du moteur (~12 Mo) sont copiés depuis
# node_modules au build par scripts/prepare-tesseract.mjs — inutile de les
# versionner. En revanche public/tesseract/lang/fra.traineddata.gz (707 Ko) EST
# versionné : il vient du réseau, et le figer évite de dépendre d'un CDN au build.
public/tesseract/*.js

# Divers
__unconfig*
todos.json
